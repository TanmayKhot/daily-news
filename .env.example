ANTHROPIC_API_KEY=sk-ant-...

# Reddit. The pipeline currently uses the unauthenticated RSS/JSON endpoints
# with an identifying User-Agent, so only REDDIT_USERNAME is read today —
# it's embedded in the UA as "ai-digest/0.1 by u/{username}" to avoid the
# generic-scraper 403s. OAuth creds stay here for when app approval comes
# through; they're inert for now.
REDDIT_USERNAME=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_PASSWORD=

# Gmail app password for SMTP delivery (16-char, no spaces). Required
# to actually send the digest; omit for --dry-run.
GMAIL_APP_PASSWORD=
# Optional: override the From/login address. Defaults to digest.config.RECIPIENT_EMAIL.
# GMAIL_SENDER=
