ANTHROPIC_API_KEY=sk-ant-...

# Reddit. The pipeline currently uses the unauthenticated RSS/JSON endpoints
# with an identifying User-Agent, so only REDDIT_USERNAME is read today —
# it's embedded in the UA as "ai-digest/0.1 by u/{username}" to avoid the
# generic-scraper 403s. OAuth creds stay here for when app approval comes
# through; they're inert for now.
REDDIT_USERNAME=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_PASSWORD=

# Brevo SMTP relay — free tier is 300 emails/day. Required to actually
# send the digest; omit for --dry-run.
#   BREVO_SMTP_LOGIN — looks like "a89cbc001@smtp-brevo.com" (shown on
#     Brevo's SMTP & API page; NOT your account email).
#   BREVO_SMTP_KEY — the generated SMTP key, begins "xsmtpsib-...".
#   SENDER_EMAIL — the verified "From" address the recipient sees.
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
SENDER_EMAIL=
