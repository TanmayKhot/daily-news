<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>AI Digest — {{ date }}</title>
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; max-width: 680px; margin: 24px auto; padding: 0 16px; line-height: 1.55; color: #222;">
  <h1 style="font-size: 22px; margin: 0 0 4px;">AI Digest</h1>
  <p style="color: #666; margin: 0 0 24px; font-size: 13px;">{{ date }} · {{ stories|length }} {{ 'story' if stories|length == 1 else 'stories' }}</p>

  {% if tldr %}
  <h2 style="font-size: 15px; margin: 24px 0 8px; text-transform: uppercase; letter-spacing: 0.04em; color: #555;">TL;DR</h2>
  <ul style="padding-left: 20px; margin: 0 0 24px;">
    {% for bullet in tldr %}
    <li style="margin-bottom: 4px;">{{ bullet }}</li>
    {% endfor %}
  </ul>
  {% endif %}

  {% for story in stories %}
  <div style="margin: 32px 0 0; padding-top: 20px; border-top: 1px solid #eee;">
    <h3 style="font-size: 16px; margin: 0 0 6px;">
      <span style="color: #888; font-weight: normal;">{{ story.source_tag }}</span>
      <a href="{{ story.url }}" style="color: #222; text-decoration: none;">{{ story.title }}</a>
    </h3>
    <p style="color: #888; margin: 0 0 12px; font-size: 12px;">
      {{ story.points }} points ·
      <a href="{{ story.discussion_url }}" style="color: #888;">{{ story.num_comments }} comments</a>
      {% if story.age %} · {{ story.age }}{% endif %}
    </p>

    <p style="font-size: 13px; color: #555; margin: 10px 0 2px; text-transform: uppercase; letter-spacing: 0.04em;">Article</p>
    {{ story.article_summary_html | safe }}

    <p style="font-size: 13px; color: #555; margin: 14px 0 2px; text-transform: uppercase; letter-spacing: 0.04em;">Discussion</p>
    {{ story.discussion_summary_html | safe }}
  </div>
  {% endfor %}

  <p style="color: #999; font-size: 12px; margin-top: 48px; text-align: center;">
    Generated by ai-digest · {{ generated_at }}
  </p>
</body>
</html>
